[sub_resource type="GDScript" id="GDScript_a202f"]
resource_name = "Cris"
script/source = "extends CharacterBody3D

var SPEED_NORMAL = 1
var SPEED_CORRIDA = 10
var correndo = false
const JUMP_HEIGHT = 5
var cam_speed = 2
var offset_camera
var alvo_movimento = global_position
var direcao = global_position.direction_to(alvo_movimento)

func _ready() -> void:
	pass



func atirar_raio_da_camera(mouse_pos: Vector2):
	var camera = get_viewport().get_camera_3d()
	var origin = camera.project_ray_origin(mouse_pos)
	var end = origin + camera.project_ray_normal(mouse_pos) * 10000
	var space_state = get_world_3d().direct_space_state

	var query = PhysicsRayQueryParameters3D.create(origin, end)
	var result = space_state.intersect_ray(query)

	if result.is_empty():
		return null
	else:
		return result.position



func _input(event: InputEvent) -> void:
	
	if event is InputEventMouseButton and event.pressed and event.button_index == MOUSE_BUTTON_RIGHT:
		var pos_3d = atirar_raio_da_camera(event.position)
		if pos_3d != null:
			var projetil = preload(\"res://projetil.tscn\").instantiate()
			get_parent().add_child(projetil)
			projetil.global_position = global_position + Vector3(0, 0.8, 0)
			projetil.alvo = pos_3d
			await get_tree().create_timer(3).timeout
			projetil.queue_free()
		
			
	if event is InputEventMouseButton:
		if event.double_click:
			print(\"yeahy\")
			correndo = true
		else:
			correndo = false
		if event.pressed and event.button_index == MOUSE_BUTTON_LEFT:
			var pos_3d = atirar_raio_da_camera(event.position)
			if pos_3d != null:
				criar_marcador(pos_3d)
				alvo_movimento = pos_3d  
				print(\"Sucesso! O mouse clicou na posição 3D: \", pos_3d)
			else:
				print(\"O raio foi atirado, mas não atingiu nenhum objeto com colisão.\")


func _process(delta: float) -> void:
	if not is_on_floor():
		velocity.y += get_gravity().y * delta
	else:
		velocity.y = 0
	
	var direcao = global_position.direction_to(alvo_movimento)
	var velocidade = SPEED_NORMAL
	if correndo:
		velocidade = SPEED_CORRIDA
	velocity.x = direcao.x * velocidade
	velocity.z = direcao.z * velocidade
	move_and_slide()
	if global_position.distance_to(alvo_movimento) < 0.1:
		velocity.x = 0
		velocity.z = 0
		correndo = false

func criar_marcador(pos):
	
	var csg = %marcador
	csg. show()
	csg.radius = 0.1
	csg.position = pos
	csg.position.y += 0.
	add_child(csg)
	await get_tree().create_timer(1).timeout
	if !Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT):
		#como nao tem animaçao eu adicionei esse await pra como se tivesse
		#acontecendo uma animaçao, mas ele nao é necessario
		await get_tree().create_timer(0.5).timeout
		csg.hide()
"

